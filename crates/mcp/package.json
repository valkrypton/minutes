{
  "name": "minutes-mcp",
  "version": "0.9.1",
  "description": "MCP server for minutes — conversation memory for AI assistants. Works with Claude Desktop, Mistral Vibe, Cursor, Windsurf, and any MCP client.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "minutes-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "dist-ui/",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "meeting",
    "transcription",
    "ai",
    "claude",
    "memory",
    "conversation",
    "whisper"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silverstein/minutes.git"
  },
  "license": "MIT",
  "author": "Mat Silverstein",
  "scripts": {
    "build": "tsc && vite build",
    "build:ui": "vite build",
    "test": "npm run build && node test/mcp_tools_test.mjs",
    "test:unit": "vitest run",
    "test:all": "vitest run && npm run build && node test/mcp_tools_test.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "minutes-sdk": "^0.9.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.1.0"
  }
}
